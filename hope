#!/data/data/com.termux/files/usr/bin/bash

HOPE="$HOME/hope-ai"

case "$1" in

start)
cd $HOPE
python core/kernel.py
;;

ai)
shift
cd $HOPE
python -c "import sys;sys.path.insert(0,'.');from ai_orchestrator.router import route;print(route('$*'))"
;;

status)
echo "HOPE OK"
;;

sync)
cd $HOPE
git add .
git commit -m "sync"
git push
;;

*)
echo "hope [start|ai|status|sync]"
;;

esac
